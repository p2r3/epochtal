// Default valve.rc configuration
exec joystick.cfg
exec autoexec.cfg
stuffcmds
startupmenu

// Filter out spectator position spew
con_filter_enable 1
con_filter_text_out "spec_goto"

// Reset autorecord behavior for srconfigs users
// Prevents some weird save-load issues
cond ?__srconfigs=1 sar_on_load sar_autorecord -1
